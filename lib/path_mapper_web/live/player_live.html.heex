<div class="player-container">
  <.live_component
    module={PathMapperWeb.WallpaperComponent}
    id="wallpaper"
    adventure={@adventure}
    game_state={@game_state}
  />

  <%= if @adventure && @game_state && @game_state.scene do %>
    <.live_component
      module={PathMapperWeb.Scene.SceneComponent}
      id="scene"
      scene_state={@scene_state}
      adventure={@adventure}
      game_state={@game_state}
      opts={%{}}
      selected_layer_index={nil}
      selected_token_index={nil}
    />
  <% end %>
</div>
